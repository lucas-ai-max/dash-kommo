# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Kommo CRM
KOMMO_API_TOKEN=your-kommo-api-token
KOMMO_SUBDOMAIN=your-subdomain

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Cron security
CRON_SECRET=your-random-secret-here

# Métricas IA (opcional): se suas tabelas tiverem outros nomes
# IA_CHATS_TABLE=chats
# IA_MESSAGES_TABLE=chat_messages

# Canal da IA: número que atende (ex: +55 41 8820-2618). Filtra métricas só deste canal.
# IA_CHANNEL_PHONE=554188202618

# Pipeline principal (sync-leads, métricas). Padrão: 11129984
# PIPELINE_ID=11129984

# Pipeline da IA (filtra métricas IA). Se não definido, usa PIPELINE_ID
# IA_PIPELINE_ID=11129984
